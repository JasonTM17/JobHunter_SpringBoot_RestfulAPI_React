{
  "name": "jobhunter-frontend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev --webpack -p 3000",
    "dev:turbo": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "clean": "node ../scripts/clean-workspace.mjs --scope=frontend --logs --temp --build",
    "clean:logs": "node ../scripts/clean-workspace.mjs --scope=frontend --logs",
    "clean:temp": "node ../scripts/clean-workspace.mjs --scope=frontend --temp"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "22.15.3",
    "@types/react": "19.1.5",
    "@types/react-dom": "19.1.5",
    "autoprefixer": "^10.4.20",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "typescript": "5.8.3"
  },
  "jest": {
    "preset": "ts-jest"
  }
}
