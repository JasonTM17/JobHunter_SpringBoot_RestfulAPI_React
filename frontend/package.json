{
  "name": "jobhunter-frontend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev --webpack -p 3000",
    "dev:turbo": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "clean": "node ../scripts/clean-workspace.mjs --scope=frontend --logs --temp --build",
