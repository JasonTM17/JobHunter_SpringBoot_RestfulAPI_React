JWT_BASE64_SECRET=replace_with_strong_base64_secret
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

API_PREFIX=/api/v1
UPLOAD_BASE_URI=file:///D:/PROJECT_INDIVIDUAL/Jobhunter/backend/storage/

SON_JPA_DDL_AUTO=update
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
