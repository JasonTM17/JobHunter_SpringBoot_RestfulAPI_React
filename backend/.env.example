# -------------------------
# Database
# -------------------------
DB_URL=jdbc:mysql://localhost:3306/jobhunter?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=172606

# -------------------------
# JWT / security
# -------------------------
# Generate a strong Base64 secret, at least 64 bytes before encoding.
JWT_BASE64_SECRET=replace_with_strong_base64_secret
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# -------------------------
# API & file storage
# -------------------------
API_PREFIX=/api/v1
UPLOAD_BASE_URI=file:///D:/PROJECT_INDIVIDUAL/Jobhunter/backend/storage/

# -------------------------
# Optional tuning
# -------------------------
SON_JPA_DDL_AUTO=update
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT_MS=30000
DB_POOL_VALIDATION_TIMEOUT_MS=5000
