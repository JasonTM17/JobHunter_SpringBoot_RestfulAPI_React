{
  "name": "jobhunter-workspace-tools",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "clean": "node scripts/clean-workspace.mjs --logs --temp",
    "clean:logs": "node scripts/clean-workspace.mjs --logs",
    "clean:temp": "node scripts/clean-workspace.mjs --temp",
    "clean:frontend": "node scripts/clean-workspace.mjs --scope=frontend --logs --temp --build",
    "clean:backend": "node scripts/clean-workspace.mjs --scope=backend --logs --temp --build",
    "clean:all": "node scripts/clean-workspace.mjs --all",
    "clean:dry": "node scripts/clean-workspace.mjs --logs --temp --dry-run",
    "clean:dry:all": "node scripts/clean-workspace.mjs --all --dry-run",
    "smoke:local": "node scripts/smoke-local.mjs",
    "qa:local": "node scripts/qa-local-production.mjs",
    "docker:build": "docker compose build backend frontend",
    "docker:build-images": "powershell -ExecutionPolicy Bypass -File scripts/docker-build-images.ps1",
    "docker:push-images": "powershell -ExecutionPolicy Bypass -File scripts/docker-push-images.ps1",
    "prod:local": "docker compose -f docker-compose.yml -f docker-compose.observability.yml -f docker-compose.backup.yml up -d --build",
    "prod:logs": "docker compose -f docker-compose.yml -f docker-compose.observability.yml -f docker-compose.backup.yml logs -f",
    "prod:down": "docker compose -f docker-compose.yml -f docker-compose.observability.yml -f docker-compose.backup.yml down",
    "staging:up": "docker compose --env-file .env.staging -f docker-compose.yml -f docker-compose.staging.yml up -d --build",
    "staging:down": "docker compose --env-file .env.staging -f docker-compose.yml -f docker-compose.staging.yml down",
    "mysql:backup": "powershell -ExecutionPolicy Bypass -File scripts/mysql-backup-now.ps1",
    "mysql:restore": "powershell -ExecutionPolicy Bypass -File scripts/mysql-restore.ps1"
  }
}
