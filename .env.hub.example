# Docker Hub image selector — replace nguyenson1710 with your actual Docker Hub username.
DOCKERHUB_USERNAME=nguyenson1710
IMAGE_TAG=latest

# Published ports
FRONTEND_PORT=3001
BACKEND_PORT=8080
DB_PORT=3307

# MySQL runtime
MYSQL_DATABASE=jobhunter
MYSQL_USER=jobhunter
MYSQL_PASSWORD=jobhunter
MYSQL_ROOT_PASSWORD=root
TZ=Asia/Ho_Chi_Minh

# Backend runtime
# PRODUCTION: change profile to 'prod' and set SEED_ENABLED=false.
SPRING_PROFILES_ACTIVE=dev,docker

# PRODUCTION: replace the JWT secret with your own base64-encoded 64-byte secret.
# Run: openssl rand -base64 64
JWT_BASE64_SECRET=REPLACE_WITH_BASE64_64_BYTE_SECRET

# Flyway — keep true for MySQL. Set false only when using a pre-existing schema.
FLYWAY_ENABLED=true
# PRODUCTION: set to 'none' so Flyway fully owns the schema.
SON_JPA_DDL_AUTO=none

# Admin bootstrap — MUST be set for production (disable SEED_ENABLED or set ADMIN_ENABLED=false first).
# When SEED_ENABLED=true: a bootstrap admin is created/updated using these credentials.
# When SEED_ENABLED=false: these values are not used.
JOBHUNTER_BOOTSTRAP_ADMIN_ENABLED=true
JOBHUNTER_BOOTSTRAP_ADMIN_EMAIL=admin@jobhunter.local
JOBHUNTER_BOOTSTRAP_ADMIN_PASSWORD=changeme
JOBHUNTER_BOOTSTRAP_ADMIN_NAME=Super Admin
# IMPORTANT: After first boot, set JOBHUNTER_BOOTSTRAP_ADMIN_ENABLED=false
# or set JOBHUNTER_SEED_ENABLED=false to prevent accidental credential resets.

# PRODUCTION: set SEED_ENABLED=false after the first successful boot.
JOBHUNTER_SEED_ENABLED=true

# Actuator + Prometheus — public endpoints for monitoring.
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# Scheduler — disabled by default. Enable in production if email system is configured.
JOBHUNTER_SCHEDULER_ENABLED=false
JOBHUNTER_MAIL_CRON_ENABLED=false
JOBHUNTER_WEEKLY_RECOMMENDATION_ENABLED=false
JOBHUNTER_LOG_CLEANUP_ENABLED=false

# Mail — configure only when SMTP is available.
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_TEMPLATE_PORTAL_URL=http://localhost:3001

# Frontend runtime URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_STORAGE_BASE_URL=http://localhost:8080
INTERNAL_API_BASE_URL=http://backend:8080
INTERNAL_STORAGE_BASE_URL=http://backend:8080
